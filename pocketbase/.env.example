# App Settings
POCKETBASE_APPLICATION_NAME=ProductBase
POCKETBASE_API_URL=http://localhost:8100

# Files Settings (Files / Backups)
S3_ENDPOINT=endpoint
S3_REGION=auto
S3_FILES_BUCKET=productbase_files
S3_BACKUPS_BUCKET=productbase_backup
S3_ACCESS_KEY_ID=access_key_id
S3_SECRET_ACCESS_KEY=secret_access_key

# Mail Settings > SMTP
SMTP_SEND_NAME=ProductBase
SMTP_SEND_ADDRESS=noreply@server.net
SMTP_SERVER=smtp.server.net
SMTP_PORT=587
SMTP_USER=user
SMTP_PASSWORD=password
